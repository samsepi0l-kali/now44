cat > .gitignore << 'EOF'
# Dependencies
node_modules/
/.pnp
.pnp.js
.pnp.mjs
.yarn/install-state.gz

# Testing
/coverage/

# Production builds
/dist-ssr/
/*.local
/build

# Development files
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# Environment variables
.env
.env.local
.env.production
.env.development
.env.test

# IDE and Editor files
.vscode/*
.idea/
*.swp
*.swo
*~
.~*
~$*
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Vite specific
.vite/
vite.config.js.timestamp-*

# Logs
logs
*.log
*.pid
*.seed
*.pid.lock

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage/
.nyc_output/

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache
.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build output
.nuxt

# Gatsby files
.cache/
public

# Storybook build output
storybook-static

# Temporary folders
tmp
temp

# dotenv environment variables file
.env*.local

# Vite plugin for React
*.mjs

# 3D model backups
*.glb.bak
*.gltf.bak

# Font backups
*.ttf.bak
*.woff.bak
*.woff2.bak

# Image backups
*.png.bak
*.jpg.bak
*.svg.bak

# API keys and secrets
.env.*
!.env.example
api-keys.txt
secrets.json
EOF